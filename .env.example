# ============================================================
#  爪爱宠物 PawCare —— 环境变量示例
#  把本文件复制成 .env（同目录）再修改
# ============================================================

# ── 服务器 ──
PORT=3000
NODE_ENV=development

# JWT 密钥（前后台共用；上线前务必改成 32+ 位随机串）
JWT_SECRET=pawcare_change_this_secret_2026

# 数据库文件路径
DB_PATH=./database/pawcare.db

# ── 后台入口 ──
# 隐藏路径，访问 /${ADMIN_PATH}/ 才能进入后台登录页
ADMIN_PATH=pawcare-admin-2026

# 初始管理员账号（首次启动后请立刻在后台改密码）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

# 上线时请设置：
# NODE_ENV=production
# ADMIN_PASSWORD=<强随机密码，不能使用默认值>
# ALLOW_MOCK_PAYMENTS=0


# ============================================================
#  短信验证码登录（SMS）
#  - dev 模式：验证码始终为 SMS_DEV_CODE，且会在服务器控制台打印
#  - aliyun / tencent：对接真实短信服务（见 server.js 中的 TODO）
# ============================================================
SMS_PROVIDER=dev
SMS_DEV_CODE=123456

# 阿里云短信（SMS_PROVIDER=aliyun 时需要）
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=爪爱宠物
ALIYUN_SMS_TEMPLATE_CODE=SMS_000000000

# 腾讯云短信（SMS_PROVIDER=tencent 时需要）
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN=爪爱宠物
TENCENT_SMS_TEMPLATE_ID=


# ============================================================
#  微信开放平台 OAuth（网站应用扫码登录）
#  申请入口：https://open.weixin.qq.com  → 创建"网站应用"
#  需要提交营业执照 + 运营团队资质，审核通过后拿到 AppID / Secret
# ============================================================

# WX_SANDBOX=1 表示本地开发沙盒：点击"微信登录"会直接模拟一个虚拟微信账号登录
# 上线前改为 0，并填入下方三项
WX_SANDBOX=1

WX_APP_ID=
WX_APP_SECRET=
# 回调地址必须与开放平台后台一致；本地可为 http://localhost:3000/api/auth/wx/callback
WX_REDIRECT_URI=http://localhost:3000/api/auth/wx/callback


# ============================================================
#  可选：速率限制、会话超时等高级参数（默认均合理，可不填）
# ============================================================
# REGISTER_RATE_PER_HOUR=20
# SMS_MAX_PER_DAY=5
# SMS_COOLDOWN_SECONDS=60
