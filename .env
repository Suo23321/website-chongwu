# 服务器配置
PORT=3000

# JWT 密钥（上线前务必修改为随机长字符串）
JWT_SECRET=pawcare_change_this_secret_2026

# 管理后台隐藏路径（上线前务必修改，不要告诉任何人）
ADMIN_PATH=pawcare-admin-2026

# 初始管理员账号（首次启动后请在后台修改密码）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

# 数据库文件路径
DB_PATH=./database/pawcare.db

# ── 短信验证码（开发模式）──
SMS_PROVIDER=dev
SMS_DEV_CODE=123456

# ── 微信登录（开发沙盒）──
WX_SANDBOX=1
WX_APP_ID=
WX_APP_SECRET=
WX_REDIRECT_URI=http://localhost:3000/api/auth/wx/callback
